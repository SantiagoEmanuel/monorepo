{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", ".env.production"],
      "globalEnv": ["NODE_ENV"],
      "env": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "type-check": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
